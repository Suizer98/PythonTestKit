ARG BASE_IMAGE=esrisg/testkit-base:latest
FROM ${BASE_IMAGE}

ENV UV_LINK_MODE=copy
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH="${JAVA_HOME}/bin:${PATH}"

RUN apt-get update \
    && apt-get install -y --no-install-recommends openjdk-17-jdk \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app

COPY pyproject.toml uv.lock /app/
COPY src ./src
COPY rules ./rules

# Mount secrets for pyproject.toml
RUN --mount=type=secret,id=secrets_username \
    --mount=type=secret,id=secrets_password \
    set -eu; \
    export UV_INDEX_DPS_USERNAME="$(cat /run/secrets/secrets_username)"; \
    export UV_INDEX_DPS_PASSWORD="$(cat /run/secrets/secrets_password)"; \
    UV_PYTHON_DOWNLOADS=auto uv sync --frozen

ENV UV_PYTHON_DOWNLOADS=never

CMD ["uv", "run", "python", "-m", "pytest", "-v", "-s"]
